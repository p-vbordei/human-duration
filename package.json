{
  "name": "human-duration",
  "version": "0.1.0",
  "description": "Parse and format human-friendly durations (\"1h30m\" ↔ 5400000ms). Zero dependencies, no Date/Intl baggage.",
  "keywords": ["duration", "time", "parse", "format", "ms", "humanize"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=18" },
  "author": { "name": "Vlad Bordei", "email": "bordeivlad@gmail.com", "url": "https://github.com/p-vbordei" },
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/p-vbordei/human-duration.git" },
  "bugs": { "url": "https://github.com/p-vbordei/human-duration/issues" },
  "homepage": "https://github.com/p-vbordei/human-duration#readme",
  "devDependencies": { "typescript": "^5.5.0", "vitest": "^2.0.0" }
}
